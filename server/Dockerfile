FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src/ src/
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
RUN apk add --no-cache tzdata
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist/ dist/
COPY migrations/ migrations/
EXPOSE 3001
CMD ["node", "dist/app.js"]
